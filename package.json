{
  "name": "pain-point-studio",
  "version": "0.1.0",
  "scripts": {
    "--- DEFAULT ---": "exit 0",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "--- LINT ---": "exit 0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "--- TEST ---": "exit 0",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@react-three/fiber": "10.0.0-alpha.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "mini-svg-data-uri": "^1.4.4",
    "motion": "^12.29.2",
    "next": "^16.1.6",
    "next-intl": "^4.8.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-no-secrets": "^2.2.1",
    "husky": "^9.0.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  },
  "private": true,
  "license": "UNLICENSED",
  "author": "Pain Point Studio Team",
  "description": "Validate product ideas before writing code. A structured research platform for developers to uncover real user pain points.",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kacper-Lechicki/pain-point-studio"
  }
}
