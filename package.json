{
  "name": "pain-point-studio",
  "version": "0.1.0",
  "scripts": {
    "--- DEFAULT ---": "exit 0",
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start",
    "prepare": "husky",
    "run:dev": "concurrently -n \"Supabase,Next\" -c \"green,blue\" \"pnpm supabase:start && pnpm supabase:studio\" \"pnpm dev\"",
    "--- LINT ---": "exit 0",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "knip": "knip",
    "--- TEST ---": "exit 0",
    "test": "vitest",
    "test:types": "tsc --noEmit",
    "test:unit": "vitest",
    "test:e2e": "pnpm supabase:restart && rm -rf .next && pnpm exec playwright install && playwright test",
    "test:all": "pnpm build && pnpm lint:fix && pnpm lint:prettier:fix && pnpm test:types && pnpm test:unit && pnpm test:e2e",
    "--- SUPABASE (local) ---": "exit 0",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:restart": "supabase stop && supabase start",
    "supabase:status": "supabase status",
    "supabase:studio": "open http://127.0.0.1:54323",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "--- SUPABASE (migrations) ---": "exit 0",
    "supabase:migration:new": "supabase migration new",
    "supabase:migration:squash": "supabase migration squash && node scripts/make-migration-idempotent.mjs",
    "supabase:migration:list": "supabase migration list",
    "--- SUPABASE (production) ---": "exit 0",
    "supabase:link": "supabase link",
    "supabase:push": "supabase db push",
    "supabase:push:dry": "supabase db push --dry-run",
    "supabase:pull": "supabase db pull",
    "supabase:diff": "supabase db diff"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.94.1",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "motion": "^12.29.2",
    "nanoid": "^5.1.6",
    "next": "^16.1.6",
    "next-intl": "^4.8.1",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.3",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "^7.71.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tippy.js": "^6.3.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/env": "16.1.6",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-no-secrets": "^2.2.1",
    "glob": "^13.0.6",
    "husky": "^9.0.0",
    "jsdom": "^27.4.0",
    "knip": "^5.85.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "supabase": "^2.76.12",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  },
  "private": true,
  "license": "UNLICENSED",
  "author": "Pain Point Studio Team",
  "description": "Validate product ideas before writing code. A structured research platform for developers to uncover real user pain points.",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kacper-Lechicki/pain-point-studio"
  }
}
