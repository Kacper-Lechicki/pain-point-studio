# Production development environment
# Copy to .env: cp .env.example .env

# Environment configuration
# Copy this file to .env.local for local development
# Copy this file to .env for production (on the server)

# --- BASIC AUTH ---
# BASIC_AUTH_USER="DEPLOY_CREDENTIALS_USERNAME"
# BASIC_AUTH_PASSWORD="DEPLOY_CREDENTIALS_PASSWORD"

# --- BUILD & CI ---
# CI="true"
# STANDALONE="true"

# --- APP CONFIG ---
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="http://painpointstudio.com"

# --- SUPABASE ---
# Public
NEXT_PUBLIC_SUPABASE_URL=<SUBSTITUTE_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_ANON_KEY=<SUBSTITUTE_SUPABASE_ANON_KEY>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<SUBSTITUTE_SUPABASE_PUBLISHABLE_KEY>

# Server
# SUPABASE_SERVICE_ROLE_KEY=<SUBSTITUTE_SUPABASE_SERVICE_ROLE_KEY>

# For local development defaults, see .env.local.example